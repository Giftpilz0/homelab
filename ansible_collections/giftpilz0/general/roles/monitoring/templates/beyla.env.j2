# Beyla eBPF auto-instrumentation environment configuration
# Reference: https://grafana.com/docs/beyla/latest/configure/options/

# What to instrument
{% if monitoring_beyla_open_port %}
BEYLA_OPEN_PORT={{ monitoring_beyla_open_port }}
{% endif %}
{% if monitoring_beyla_executable_name %}
BEYLA_EXECUTABLE_NAME={{ monitoring_beyla_executable_name }}
{% endif %}

# Prometheus metrics exposure (scraped by Alloy)
BEYLA_PROMETHEUS_PORT={{ monitoring_beyla_prometheus_port }}
BEYLA_PROMETHEUS_PATH=/metrics

{% if monitoring_beyla_otlp_endpoint %}
# OTLP trace export
OTEL_EXPORTER_OTLP_ENDPOINT={{ monitoring_beyla_otlp_endpoint }}
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
{% endif %}

# Log level: DEBUG, INFO, WARN, ERROR
BEYLA_LOG_LEVEL=WARN
