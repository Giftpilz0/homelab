{% if misc_envoy_enabled %}
[Unit]
Description=Misc Envoy Proxy
After=misc.service

[Container]
ContainerName=misc-envoy
Image=docker.io/envoyproxy/envoy:v{{ misc_envoy_version }}

Pod=misc.pod

Volume=%h/.config/containers/systemd/misc-pod/config/envoy.yaml:/etc/envoy/envoy.yaml:ro

[Service]
Restart=always

[Install]
WantedBy=multi-user.target default.target
{% endif %}
