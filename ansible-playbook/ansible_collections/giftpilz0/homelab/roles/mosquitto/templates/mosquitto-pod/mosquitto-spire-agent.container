{% if mosquitto_spire_enabled %}
[Unit]
Description=Mosquitto SPIRE Agent
After=mosquitto.service

[Container]
ContainerName=mosquitto-spire-agent
Image=ghcr.io/spiffe/spire-agent:{{ mosquitto_spire_agent_version }}

Pod=mosquitto.pod

Volume=%h/.config/containers/systemd/spire-pod/config/bundle.crt:/run/spire/agent/bootstrap.crt:Z
Volume=%h/.config/containers/systemd/mosquitto-pod/config/spire-agent.conf:/etc/spire/agent/agent.conf:Z
Volume=%h/.config/containers/systemd/mosquitto-pod/data:/run/spire/data:Z
Volume=%h/.config/containers/systemd/mosquitto-pod/token:/run/spire/agent/token:Z
Volume=mosquitto-spire-sockets:/run/spire/agent:Z

Exec=/opt/spire/bin/spire-agent run -config /etc/spire/agent/agent.conf -joinToken $(cat /run/spire/agent/token)
{% endif %}
